{
  "name": "@unveiled/web",
  "private": true,
  "type": "module",
  "scripts": {
    "css:build": "tailwindcss -i ./app/styles/globals.css -o ./public/assets/globals.css",
    "css:watch": "tailwindcss -i ./app/styles/globals.css -o ./public/assets/globals.css --watch",
    "dev:vite": "vite",
    "dev": "bun ./scripts/dev.ts",
    "build": "bun run css:build && vite build --mode client && vite build",
    "start": "cd dist && node index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@better-auth-ui/core": "^1.6.27",
    "@better-auth-ui/heroui": "^1.6.27",
    "@better-auth-ui/react": "^1.6.27",
    "@heroui/react": "^3.2.1",
    "@heroui/styles": "^3.2.1",
    "@hono/node-server": "^2.0.8",
    "@hono/react-renderer": "^0.2.0",
    "@internationalized/date": "^3.12.2",
    "@react-aria/ssr": "^3.10.1",
    "@tanstack/react-query": "^5.101.2",
    "@unveiled/auth": "workspace:*",
    "@unveiled/db": "workspace:*",
    "@unveiled/images": "workspace:*",
    "better-auth": "^1.6.23",
    "clsx": "^2.1.1",
    "hono": "^4.7.0",
    "honox": "^0.1.56",
    "maplibre-gl": "^5.24.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.0.0",
    "@hono/vite-dev-server": "^0.18.0",
    "@tailwindcss/cli": "^4.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@unveiled/config": "workspace:*",
    "tailwindcss": "^4.3.2",
    "typescript": "catalog:",
    "vite": "^6.0.0"
  }
}
