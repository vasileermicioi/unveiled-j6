# Unveiled Berlin — local development (copy to .env at repo root; never commit .env)
# Bun loads this file for: bun run dev, db:migrate, seed:demo, package tests

# --- Phase 2+ (auth + database) ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
AUTH_URL=https://YOUR-NEON-AUTH-HOST/neondb/auth

# --- Phase 1+ (SEO absolute URLs; optional locally — defaults to http://localhost:3000) ---
SITE_URL=http://localhost:3000

# --- Phase 4+ (Cloudflare R2 image pipeline) ---
# S3 API endpoint: host only — NO bucket path (Cloudflare shows ...r2.cloudflarestorage.com/BUCKET)
S3_ENDPOINT=https://YOUR-ACCOUNT-ID.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=unveiled-j6
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Public read URL (R2.dev subdomain or custom domain) — NOT the S3 API endpoint
IMAGE_PUBLIC_BASE_URL=https://pub-XXXXXXXX.r2.dev

# --- Optional ---
# PORT=3000
# Comma-separated emails auto-promoted to ADMIN on session resolve (staging/dev only)
# ADMIN_PROMOTE_EMAILS=you@example.com

# --- Phase 4½ (Playwright E2E) ---
E2E_USER_EMAIL=
E2E_USER_PASSWORD=
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
# Set to 1 only when driving hosted Stripe Checkout in Playwright (+ stripe listen)
# E2E_STRIPE_CHECKOUT=

# --- Phase 6+ (Stripe Billing + Resend) — required on staging for payment demos ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID_BASIC_BERLIN=price_...
# RESEND_API_KEY=re_...
# DAILY_CODES_FROM_EMAIL=noreply@unveiled.berlin

# --- Later phases ---
# Event map (Phase 5): MapLibre GL JS + OpenStreetMap tiles — no env vars required
# SENTRY_DSN=
