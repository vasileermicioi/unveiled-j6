{
  "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
  "root": false,
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "apps/**",
      "e2e/**",
      "packages/**",
      "scripts/**",
      "package.json",
      "biome.json",
      "bunfig.toml"
    ]
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  }
}
